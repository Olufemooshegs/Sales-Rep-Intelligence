# Database URL (asyncpg)
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/salesdb

# JWT
SECRET_KEY=CHANGE_ME_TO_A_STRONG_SECRET
ACCESS_TOKEN_EXPIRE_MINUTES=1440
ALGORITHM=HS256

# Optional Redis for caching (e.g., redis://localhost:6379)
REDIS_URL=

# Optional initial admin seeding
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=changeme
